#!/bin/sh
# Pre-commit gate for mlx-rs.
#
# Always runs `cargo clippy --workspace --all-targets -- -D warnings`.
# The workspace is at 0 warnings/0 errors; the gate keeps it that way.
#
# rustfmt is intentionally commented out: the project is in heavy refactor
# and a blanket fmt run reformats sibling modules outside the staged set.
# Re-enable when churn settles.

set -e

STAGED_RUST=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')

if [ -z "$STAGED_RUST" ]; then
	exit 0
fi

