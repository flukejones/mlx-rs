#!/bin/sh
# Pre-commit gate for mlx-rs.
#
# 1. Auto-fmt any staged Rust files (in-place) and fold the fmt diff
#    into the commit. Partially-staged files are handled safely: we
#    stash the unstaged portion before fmt, fmt the index view, then
#    restore the stash. If rustfmt fails on any file, the commit is
#    aborted so the user sees the error.
# 2. Run `cargo clippy --workspace --all-targets -- -D warnings`.
#    The workspace is at 0 warnings/0 errors; the gate keeps it that
#    way.

set -e

STAGED_RUST=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')

if [ -z "$STAGED_RUST" ]; then
	exit 0
fi

# --- rustfmt staged-only, partial-stage safe ---
# Stash the unstaged tracked changes so the working tree matches the
# index. rustfmt then operates on exactly what's being committed.
# `--keep-index` keeps staged hunks intact. Trap restores on any exit
# path so a rustfmt or clippy failure doesn't leave the user stuck.
HAVE_UNSTAGED=0
if ! git diff --quiet; then
	HAVE_UNSTAGED=1
fi

if [ "$HAVE_UNSTAGED" -eq 1 ]; then
	git stash push --keep-index --include-untracked -m "pre-commit-hook-autostash" >/dev/null
	# shellcheck disable=SC2317
	restore_stash() {
		git stash pop --quiet 2>/dev/null || true
	}
	trap restore_stash EXIT
fi

echo "$STAGED_RUST" | xargs rustfmt --edition 2021
# Re-stage any rustfmt rewrites so they land in this commit.
echo "$STAGED_RUST" | xargs git add

echo '+ cargo clippy --workspace --all-targets -- -D warnings'
cargo clippy --workspace --all-targets -- -D warnings
