# --- clippy per affected crate ---
# Map staged paths to crate names and dedupe.
CRATES=$(echo "$STAGED_RUST" | awk -F/ '
	/^mlx-sys\//             { print "mlx-sys" }
	/^mlx-rs\//              { print "mlx-rs" }
	/^mlx-lm\//              { print "mlx-lm" }
	/^mlx-lm-utils\//        { print "mlx-lm-utils" }
	/^mlx-macros\//          { print "mlx-macros" }
	/^mlx-internal-macros\// { print "mlx-internal-macros" }
	/^mlx-tests\//           { print "mlx-tests" }
	/^xtask\//               { print "xtask" }
' | sort -u)

if [ -z "$CRATES" ]; then
	# Staged Rust lives only in examples/ or similar — skip the workspace
	# clippy gate since examples have their own detached workspaces.
	exit 0
fi

for crate in $CRATES; do
	echo "+ cargo clippy -p $crate --all-targets -- -D warnings"
	cargo clippy -p "$crate" --all-targets -- -D warnings
done
